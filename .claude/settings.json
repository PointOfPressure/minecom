{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/backup-changed-file.sh",
            "timeout": 10,
            "statusMessage": "Backing up file before edit"
          }
        ]
      }
    ]
  }
}
